# Variables d'environnement Supabase.
# Copier ce fichier en .env.local puis remplir les vraies valeurs.
# .env.local est ignore par git (voir .gitignore) : ne jamais committer de cle.
#
# Ces valeurs se trouvent dans le dashboard Supabase :
# Project Settings -> API -> Project URL et Project API keys (cle "anon public").

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique
